{
  "name": "glow-me-webshop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run startStripeListener\" \"vite dev\"",
    "startStripeListener": "stripe listen --forward-to localhost:8888/.netlify/functions/stripeWebhook --events checkout.session.completed,refund.created",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "lighthouse": "lighthouse http://localhost:8888 --output-path ./dist/lighthouse-results.html --view --chrome-flags=\"--headless\""
  },
  "dependencies": {
    "@netlify/functions": "^5.2.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/supabase-js": "^2.105.1",
    "bootstrap": "^5.3.8",
    "dinero.js": "^2.0.2",
    "dotenv": "^17.4.2",
    "locale-currency": "^1.0.0",
    "lordis-react-components": "^1.5.6",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dinero.js": "^1.9.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lighthouse": "^13.0.3",
    "netlify-cli": "^24.5.1",
    "prettier": "3.8.1",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
